# 실제 값은 backend/.env 에 넣는다. .env 는 커밋되지 않는다(.gitignore, 결정사항 D18).
# 개발용 LLM 프로바이더: Google Gemini (gemini-2.5-flash, 무료 티어)
GEMINI_API_KEY=your-gemini-api-key-here

# JWT 서명 키(HS256, 최소 32바이트). 운영에서는 반드시 강한 값으로 교체 (결정사항 D21).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
# (선택) 액세스 토큰 유효기간(초). 미설정 시 3600(1시간).
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=3600
